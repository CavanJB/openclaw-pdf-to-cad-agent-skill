{
  "schema_version": "0.1",
  "name": "openclaw-pdf-to-cad",
  "display_name": "OpenClaw PDF to CAD",
  "kind": "agent_skill",
  "target_runtime": "openclaw",
  "runtime": "local_script",
  "description": "Convert PDF engineering drawings into CAD-oriented delivery packages for OpenClaw agents.",
  "entrypoint": "scripts/run_pdf_to_cad.sh",
  "supported_inputs": [".pdf"],
  "unsupported_inputs": [".step", ".stp", ".iges", ".igs", ".stl", ".sldprt", ".sldasm"],
  "outputs": [
    "layered DXF",
    "optional DWG",
    "PNG preview",
    "PDF preview",
    "quality_report.json",
    "delivery README",
    "zip package"
  ],
  "quality_policy": {
    "no_guessing_dimensions": true,
    "scanned_or_mixed_pdf_requires_review": true,
    "report_needs_review_explicitly": true,
    "preserve_unicode_cjk_text": true,
    "garbled_text_requires_review": true,
    "do_not_recommend_unverified_cjk_dwg": true,
    "preserve_text_baseline_position": true,
    "preserve_text_rotation": true,
    "ocr_fallback_must_be_reported": true
  },
  "agent_contract": {
    "primary_runtime": "OpenClaw",
    "is_subagent": false,
    "is_3d_converter": false,
    "requires_pdf_input": true,
    "must_return_delivery_package": true
  }
}
