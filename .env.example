# Optional: path to a DXF -> DWG converter such as QCAD's dwg2dwg.
# If unset, the skill will still produce DXF + PDF/PNG preview.
OPENCLAW_DWG_CONVERTER=

# Optional: path to Tesseract OCR binary (auto-detected from PATH if unset).
# OPENCLAW_TESSERACT=/usr/local/bin/tesseract

# Optional: OCR languages for Tesseract (default: chi_sim+eng).
# OPENCLAW_OCR_LANGS=chi_sim+eng

# Optional: CJK font override for text rendering (auto-detected per-platform if unset).
# OPENCLAW_CJK_FONT=/path/to/custom-font.ttf

# Optional: directory to scan for CJK fonts.
# OPENCLAW_CJK_FONT_DIR=/path/to/fonts/

# Optional: path to YAML configuration file (default: openclaw-pdf-to-cad.yaml).
# OPENCLAW_CONFIG=/path/to/config.yaml
